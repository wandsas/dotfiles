[color]
	ui = true
[core]
    editor = $EDITOR
    whitespace=fix,space-before-tab,tab-in-indent,trailing-space,cr-at-eol
    pager = less -FRSX
	compression = 9
    excludesfile = ${XDG_CONFIG_HOME}/git/gitignore_global
    attributesfile = ${XDG_CONFIG_HOME}/git/attributes
    hooksPath = ${XDG_CONFIG_HOME}/git/template/hooks
[commit]
  gpgsign = false
[gpg]
  program = /usr/bin/gpg
[ghq]
  root = ${HOME}/repos
[gui]
  fontui   = -family terminus -size 9 -weight normal -slant roman -underline 0 -overstrike 0
  fontdiff = -family terminus -size 9 -weight normal -slant roman -underline 0 -overstrike 0
  editor = nvim-gtk
[init]
	templateDir = ${XDG_CONFIG_HOME}/git/template/hooks
[interactive]
  diffFilter = diff-so-fancy --patch-mode | less --tabs=4 -RFX
[log]
  decorate = short
[pager]
  show = diff-so-fancy | less --tabs=4 -RFX --pattern '^(Date|added|deleted|modified): '
  diff = diff-so-fancy | less --tabs=4 -RFX --pattern '^(Date|added|deleted|modified): '
[push]
	default = simple
[receive]
	denyCurrentBranch = warn
[sendemail]
	from = Sascha Wander <sascha.wander@gmail.com>
[stash]
	showPatch = true
[transfer]
	fsckObjects = true
[user]
	email = sascha.wander@gmail.com
	name = Sascha Wander
	signingkey = 0xF6BC73162CFD2DBD


[color]
  branch = yes
  pager = yes
  diff = auto
  status = auto
  interactive = always
  showbranch = auto
  ui = auto
[color "branch"]
  current = green
  local = yellow
  remote  = cyan
[color "diff"]
  meta = yellow
  frag = magenta
  old = red
  new = green
[color "diff-highlight"]
  oldNormal = red strike
  oldHighlight = red 52 strike
  newNormal = green italic
  newHighlight = green 22 italic
[color "interactive"]
    error = red bold
[color "status"]
  header = magenta
  added = yellow
  changed = green
  untracked = cyan
