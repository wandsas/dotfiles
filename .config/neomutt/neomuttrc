# $Id: ~/.neovimrc wandsas 2018/08/13

# My config for the Neovim E-Mail Client - Teaching an Old Dog New Tricks

# {{{ References

# Neomutt Guide     https://www.neomutt.org/guide/

# Neomutt           Cmdline Reference https://www.neomutt.org/guide/reference

# MSMTP             http://msmtp.sourceforge.net/doc/msmtp.html

# Offlineimap       http://www.offlineimap.org/documentation.html

# Mairix Indexing   http://www.rpcurnow.force9.co.uk/mairix/

# Procmail          http://pm-doc.sourceforge.net/doc/

# }}}

# {{{ Include files

set alias_file       = ~/.neomutt/aliases
set header_cache     = ~/.neomutt/cache/headers
set message_cachedir = ~/.neomutt/cache/bodies
set certificate_file = ~/.neomutt/certificates
set mailcap_path     = ~/.neomutt/mailcap
set signature        = ~/.neomutt/signature.html
set tmpdir           = /tmp

source ~/.neomutt/themes/solarized-256
source ~/.neomutt/lists
source ~/.neomutt/aliases

# }}}

# {{{ Basic options

set wait_key = no               # shut up, mutt
set timeout = 0                 # idle before scanning
set mail_check = 0              # minimum time between scans
unset move                      # gmail does that
set delete                      # do not ask, just do !
unset confirmappend             # do not ask, just do !!
set quit                        # do not ask, just do !!!
unset mark_old                  # read/new is good enough for me
set beep_new                    # bell on new mails
set pipe_decode                 # strip headers and eval mimes when piping
set thorough_search             # strip headers and eval mimes before searching
set recall=no                   # don't ask to recall postponed msg when composing
set delete=yes                  # don't ask to confirm purge deleted msg on sync
unset record                    # gmail smtp already copies emails to sent folder
set autoedit
set read_inc=10                 # show count number for every tenth mail
set write_inc=10                # update number after each tenth read mail

# }}}

# {{{ Sidebar

### Sidebar view options ###
set sidebar_visible = yes
set sidebar_width   = 20

### Sidebar keybindings ###
bind index,pager <down>    sidebar-next
bind index,pager <up>      sidebar-prev
bind index,pager <right>   sidebar-open

# toggle sidebar
macro index b '<enter-command>toggle sidebar_visible<enter><refresh>'
macro pager b '<enter-command>toggle sidebar_visible<enter><redraw-screen>'

# }}}

# {{{ Statusbar

### Statusbar view options ###
set status_on_top
set status_chars   = " *%A"
set status_format  = "Folder: %f : %r%n new (%m messages)%?d? (%d to delete)?%?t? (%t tagged)? %>-%?p?( %p postponed )? : "

### Statusbar format description ###
# status_format - format of summary on the current folder in the index
# meta strings:
#  -----f-h---lmn-p-rst-v----  lower case letters (10)
#  ------------M----------X--  upper case letters (02)
#
# %d      the number of messages with the flag 'delete'  (v64)
# %f      the full pathname of the current mailbox
# %h      local hostname
# %l      size (in bytes) of the current mailbox
# %m      the number of messages in the mailbox
# %M      the number of messages shown (i.e., which match the current limit)
# %n      number of new messages in the mailbox
# %p      number of postponed messages
# %s      current sorting mode
# %r      modified/read-only/won't-write/attach-message indicator-status_chars
# %t      number of tagged messages
# %v      Mutt version string
# %>X     right justify the rest of the string and pad with "X"
# %|X     pad to the end of the line with "X"
#
# %?<sequence_char>?<optional_string>? optionally print string, if>0

### Statusbar Examples ###
