; {{{ General settings

[settings]
screenchange-reload = true
;compositing-background = over         ; options: over, screen, xor
;compositing-foreground = difference   ; options: difference, over, source
;compositing-overline = over
;compositing-underline = over
;compositing-border = over


[global/wm]
margin-top = 5
margin-bottom = 5
;fixed-center = true
;override-redirect = true

