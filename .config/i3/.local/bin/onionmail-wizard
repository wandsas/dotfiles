		continue

	if par == "-u":
		if idx == pha1:
			print "Syntax error"
			sys.exit(1)

		CONF['user'] = sys.argv[idx+1]
		if CONF['user'] == "root":
			CONF['home']="/root"
		else:
			CONF['home']="/home/"+CONF['user']
		CONF['setusr'] = CONF['user']
		if not os.path.isdir(CONF['home']):
			print "Invalid home directory"
			sys.exit(1)
		pha2=1

	if par == "-uh":
		if idx == pha1:
			print "Syntax error"
			sys.exit(1)

		CONF['home'] = sys.argv[idx+1]
