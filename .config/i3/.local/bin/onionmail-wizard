	[ 0,0,6,8,0,0,0,5,5,0,0,0,0,6,4,0,0,	Col["blue"]+"Writed KB: %wbyk%" 			]	,
	[ 8,0,0,7,0,3,0,9,9,0,0,0,7,3,0,0,8,	Col["blue"]+"Time elapsed: %tmp% S" 			]	]
	# New matrix, more tempest inteference.
	# More fastest on virtual machine.


def csh(arg):
        return '"%s"' % (
                arg
                .replace('\\','\\\\')
                .replace('"','\\"')
                .replace('$','\\$')
                .replace('`','\\`')
        )

def AutoRave(proc):
	"Experimental: Entropy, Tempest/interference generator. It follows the Furamide project specification #1."
	try:
		os.system("stty -echo")
		print Col["red"]+"Move your mouse as randomly as possible. The longer you move it, the better."
		print "This significantly increases the system entropy and cryptographic stregth of the encryption keys."
		print Col["purple"]+"I try to create some entropy by the AutoRave."+Col["0"]
		print Col["purple"]+"I try to create some radio interference to tempest using the AutoRave."+Col["0"]
		print Col["blue"]+"If you want to interrupt this process press CTRL+C"+Col["0"]+"\n"
		R = open("/dev/urandom","r")

		Pal = Col.values()
		MPal = len(Pal)

		Alfa="0123456789"
		MAlfa = len(Alfa)
		print "  ABCDEFGHIJKLMNO"
		for y in range(8):
			print y

		O = open("/dev/null","w")
		rd=""
		TX = { "c" : 0 , "rby" : 0, "wby" : 0};
		STime = int(time.time())
		# Furamide spec. #1
		while proc.poll() == None:
			X = open("/proc/sys/kernel/random/entropy_avail","r")
			TX['ent'] = X.read()
			TX['ent'] = TX['ent'].strip()
			X.close()
			TX['c'] = TX['c']+1
			TX['tmp'] = int(time.time()) - STime
			reg = 8
			rs = len(rd)
			TX['rby'] = TX['rby'] + rs
			TX['rbyk'] = int(TX['rby']/1024)
			TX['wbyk'] = int(TX['wby']/1024)
			O.write(rd)
			if rs>4:
				rs=4

			for x in range(rs):
				o = ord(rd[x])
				b = o & 7
				a = int(o/8) & 15
				QBMatrix[b][a] ^= o

			print "\033[9A"
			qq=""
			# signal int.
			for y in range(8):
				st=""
				for x in range(15):
					c = QBMatrix[y][x]
					c = c + QBMatrix[ (y+1) & 7 ][ (x+1) & 15]
					c = c + QBMatrix[ (y-1) & 7 ][ (x-1) & 15]
					c = c + QBMatrix[ (y+1) & 7 ][ (x-1) & 15]
					c = c + QBMatrix[ (y-1) & 7 ][ (x+1) & 15]
					c = c ^ int(c/2)
					reg = reg ^ c
					c = c & 255
					QBMatrix[y][x] = c
					n = c % MAlfa
					n = Alfa[n]
					c = c % MPal
					c = Pal[c]
					st = st + c + n
				print y,st+Col["0"],
				t = QBMatrix[y][17]

				for k,v in TX.items():
					t = t.replace("%"+k+"%",Col["green"]+str(v))

				print "\t",t+Col["0"]
				qq = qq + st+"\n"
			reg=reg&15
			rd = R.read(1+reg*100)
			O.write(qq)
			TX['wby'] = TX['wby'] + len(qq)+len(rd)
			random.seed( random.randrange(1,9999999) + reg)
			r = reg + random.randrange(1,100)
			r = 2 + (r % 10)
			time.sleep(1/r) # signal int.
		R.close()
		O.close()
	except KeyboardInterrupt:
		print "\033[2J\033[0;0H\n"
		proc.kill()
		print Col["red"]+" Key generation interrupted! "+Col["0"]
		print Col["cyan"]+"No GPG key available!"+Col["0"]+"\n"		
	except:
		print "\033[2J\033[0;0H\n"
		print Col["red"]+" AutoRave Error!!! "+Col["0"]
	os.system("stty echo")	
	print "\n"

def getDesktop():
	"Experimental: Get desktop env."
	base = os.environ['HOME']
	base = base + "/.config/user-dirs.dirs"
	if not os.path.isfile(base):
		return ""

	cmd="cat "+csh(base)+""" | egrep -iEv '\s*\#' | egrep -m 1 -iE '\s*XDG\_DESKTOP\_DIR\s*=\s*\"' | egrep -iEo '\"[^"]+\"' | egrep -iEo '[^"]+'"""
	p = subprocess.Popen(cmd,shell=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, stdin=subprocess.PIPE)
	rs = p.stdout.read()
	if p.wait()!=0:
		return ""

	rs=rs.strip()
	for k,v in os.environ.items():
		rs=rs.replace('$'+k,v)
	return rs

